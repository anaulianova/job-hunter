# job-hunter: personal data — never commit
cv.md
profile/user_profile.json
config/google_creds.json
pipeline/pipeline.json
pipeline/scan_log.json
pipeline/reports/*
!pipeline/.gitkeep
!pipeline/reports/.gitkeep

# Claude Code internal
.claude/

# job-hunter: generated output — never commit
# Ignore contents but keep the folders (via .gitkeep) so they exist after cloning
submitted/*
tailored/*
jds/*
!submitted/.gitkeep
!tailored/.gitkeep
!jds/.gitkeep
config/targets.yml

# Secrets
.env

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# macOS / editors
.DS_Store
.vscode/
.idea/
*.swp
